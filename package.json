{
  "name": "sunday-musician",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run typecheck && npm run lint && npm run test:quality && npm run test:unit",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:quality": "node --test tests/quality/*.test.mjs",
    "test:unit": "find src -name '*.test.ts' -print0 | xargs -0 tsx --test",
    "predeploy": "npm run build"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.5",
    "node-ical": "^0.26.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}

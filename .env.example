# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe Dashboard → Webhooks → your endpoint.
# This is the "whsec_..." value, NOT the endpoint URL.
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@sundaymusician.com

# Optional: Resend template IDs (leave blank to use inline HTML templates)
RESEND_TEMPLATE_CARD_EXPIRING_REMINDER=

# ─── App ───────────────────────────────────────────────────────────────────────
# Full URL of the deployment, no trailing slash. Used for email links and Stripe
# redirect URLs. Example: https://app.sundaymusician.com
SITE_URL=

# Secret for authenticating cron job requests. Generate with:
#   openssl rand -base64 32
CRON_SECRET=
